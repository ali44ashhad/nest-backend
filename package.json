{
  "name": "nesta-toys-backend",
  "version": "1.0.0",
  "description": "backend repo",
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "serve": "node dist/index.js",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "security-check": "npm audit",
    "prestart": "npm run build",
    "precommit": "npm run lint && npm test",
    "format": "prettier --write \"src/**/*.ts\"",
    "validate": "npm run lint && npm run security-check && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amitkumarc72/Nesta-toys-Backend.git"
  },
  "author": "Shudhanshu Jaiswal",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/amitkumarc72/Nesta-toys-Backend/issues"
  },
  "homepage": "https://github.com/amitkumarc72/Nesta-toys-Backend#readme",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "pino": "^8.21.0",
    "pino-http": "^8.6.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^24.0.10",
    "@types/pg": "^8.15.4",
    "@types/pino": "^7.0.5",
    "@types/pino-http": "^5.8.4",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.47.0",
    "jest": "^30.0.4",
    "nodemon": "^3.1.10",
    "pino-pretty": "^10.2.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
